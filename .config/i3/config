# i3 config file (v4)
#
# Please see https://i3wm.org/docs/userguide.html for a complete reference!

# Mod4 - Windows
# Mod1 - Alt
set $mod Mod4

# Use Mouse+$mod to drag floating windows to their wanted position
floating_modifier $mod

include $HOME/.config/i3/config.d/ui.conf
include $HOME/.config/i3/config.d/startup.conf
include $HOME/.config/i3/config.d/layout.conf
include $HOME/.config/i3/config.d/motion.conf
include $HOME/.config/i3/config.d/action.conf
include $HOME/.config/i3/config.d/launch.conf
include $HOME/.config/i3/config.d/workspace.conf
include $HOME/.config/i3/config.d/window.conf
