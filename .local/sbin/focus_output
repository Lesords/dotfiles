#!/bin/bash

direction="$1"

# 获取所有连接的显示器
outputs=($(xrandr --query | grep " connected" | awk '{print $1}'))

# 获取当前焦点所在显示器
current_output=$(i3-msg -t get_workspaces | jq -r '.[] | select(.focused==true) | .output')

# 找到当前显示器索引
for i in "${!outputs[@]}"; do
    if [[ "${outputs[$i]}" == "$current_output" ]]; then
        current_index=$i
        break
    fi
done

total=${#outputs[@]}

if [[ "$direction" == "prev" ]]; then
    next_index=$(( current_index - 1 ))
else
    next_index=$(( current_index + 1 ))
fi

if (( total >= 3 )); then
    next_index=$(( (next_index + total) % total ))
elif (( next_index < 0 || next_index >= total )); then
    next_index=$current_index
fi

next_output=${outputs[$next_index]}

i3-msg "focus output $next_output"
